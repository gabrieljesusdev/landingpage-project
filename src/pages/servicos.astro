---
import Layout from "../layouts/Layout.astro";
import SiteNavbar from "../components/SiteNavbar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import technician1 from "../assets/bg-technician-1.jpg";
import technician2 from "../assets/bg-technician-2.jpg";
import technician3 from "../assets/bg-technician-3.jpg";

const services = [
  {
    title: "Manutenção de Ar Condicionado",
    href: "/servicos/ar-condicionado",
    image: technician1,
    alt: "Técnico realizando manutenção de ar-condicionado",
    description:
      "Limpeza técnica, ajustes de performance e reparos para manter o sistema eficiente.",
  },
  {
    title: "Manutenção de Gerador",
    href: "/servicos/gerador",
    image: technician2,
    alt: "Equipe técnica em manutenção de gerador",
    description:
      "Revisão preventiva, testes de carga e correções para evitar paradas inesperadas.",
  },
  {
    title: "Manutenção Elétrica",
    href: "/servicos/eletrica",
    image: technician3,
    alt: "Profissional em inspeção elétrica",
    description:
      "Diagnóstico de falhas, ajustes de segurança e reparos em circuitos e painéis.",
  },
  {
    title: "Manutenção Hidráulica",
    href: "/servicos/hidraulica",
    image: technician1,
    alt: "Técnico executando manutenção hidráulica",
    description:
      "Correção de vazamentos, revisão de pressão e manutenção em tubulações e conexões.",
  },
];
---

<Layout
  title="Entrans | Serviços"
  description="Veja os serviços oferecidos pela Entrans em manutenção de ar-condicionado, gerador, elétrica e hidráulica."
>
  <SiteNavbar />
  <main
    class="mx-auto flex w-full max-w-295 flex-col px-4 py-28 sm:px-6 lg:px-10"
  >
    <span class="w-fit rounded-pill py-1 text-sm font-semibold text-primary">
      Serviços
    </span>
    <h1
      class="mt-4 font-display text-h2 font-bold leading-[1.1] text-text-strong"
    >
      Galeria de Ar Condicionado
    </h1>
    <p class="mt-3 max-w-2xl text-base leading-[1.45] text-text-body">
      Explore nossa galeria de serviços especializados em manutenção de
      ar-condicionado.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4"></div>

    <a
      href="/"
      class="mt-8 inline-flex w-fit items-center rounded-pill bg-primary px-5 py-3 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:brightness-110"
    >
      Voltar para o início
    </a>
  </main>
  <SiteFooter />
</Layout>
