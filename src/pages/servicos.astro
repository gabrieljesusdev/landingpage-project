---
import Layout from "../layouts/Layout.astro";
import SiteNavbar from "../components/SiteNavbar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { siteContent } from "../lib/cms";

const section = siteContent.servicesPage;
---

<Layout
  title={section.title}
  description={section.description}
>
  <SiteNavbar />
  <main
    class="mx-auto flex w-full max-w-295 flex-col px-4 py-28 sm:px-6 lg:px-10"
  >
    <span class="w-fit rounded-pill py-1 text-sm font-semibold text-primary">
      {section.badge}
    </span>
    <h1
      class="mt-4 font-display text-h2 font-bold leading-[1.1] text-text-strong"
    >
      {section.heading}
    </h1>
    <p class="mt-3 max-w-2xl text-base leading-[1.45] text-text-body">
      {section.intro}
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {
        section.cards.map((service) => (
          <a
            href={service.href}
            class="group flex flex-col overflow-hidden rounded-md border border-border-soft bg-bg-surface shadow-soft transition-all duration-200 hover:-translate-y-0.5"
          >
            <img
              src={service.image}
              alt={service.alt}
              class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="p-4">
              <h2 class="text-base font-semibold text-text-strong">{service.title}</h2>
              <p class="mt-1 text-sm leading-[1.45] text-text-body">{service.description}</p>
            </div>
          </a>
        ))
      }
    </div>

    <a
      href="/"
      class="mt-8 inline-flex w-fit items-center rounded-pill bg-primary px-5 py-3 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:brightness-110"
    >
      {section.backText}
    </a>
  </main>
  <SiteFooter />
</Layout>
