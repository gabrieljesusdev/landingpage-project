---
import technician from "../assets/bg-technician.jpg";
---

<section
  id="inicio"
  class="relative flex min-h-[86vh] w-full items-center justify-center overflow-hidden"
  data-reveal
>
  <img
    src={technician.src}
    alt="Técnico realizando manutenção em ar-condicionado"
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
  />

  <div class="absolute inset-0 bg-[var(--bg-hero-overlay)]"></div>
  <!-- <div class="hero-glow hero-glow-blue"></div>
  <div class="hero-glow hero-glow-orange"></div> -->

  <div
    class="relative mx-auto flex w-full max-w-[1180px] flex-col items-center px-4 pt-24 text-center sm:px-6 lg:px-10"
  >
    <h1
      class="max-w-4xl text-hero-title font-bold leading-[1.12] text-white"
      data-reveal
      data-reveal-delay="1"
    >
      Assistência técnica profissional
      <br />
      para ar-condicionado
      <br />
      <span class="text-secondary">residencial</span>
      e
      <span class="text-primary">comercial.</span>
    </h1>

    <p
      class="mt-3 max-w-2xl text-base font-medium text-white/88 sm:text-[1.2rem]"
      data-reveal
      data-reveal-delay="2"
    >
      Diagnóstico profissional e atendimento eficiente.
    </p>

    <a
      href="#contato"
      aria-label="Solicitar orçamento gratuito agora"
      class="mt-7 rounded-pill bg-secondary px-7 py-3 text-base font-semibold text-white shadow-button transition-all duration-200 hover:-translate-y-0.5 hover:brightness-110"
      data-reveal
      data-reveal-delay="3"
    >
      Solicitar orçamento gratuito
    </a>

    <div
      class="mt-4 flex flex-wrap items-center justify-center gap-3 text-sm sm:text-[0.95rem]"
    >
      <span class="font-medium text-secondary">+1000 clientes atendidos</span>
      <span class="text-star">★ 5 estrelas no Google</span>
    </div>
  </div>
</section>

<style>
  .hero-glow {
    position: absolute;
    width: 26rem;
    height: 26rem;
    border-radius: 999px;
    filter: blur(var(--blur-hero-glow));
    z-index: 1;
  }

  .hero-glow-blue {
    left: -5rem;
    top: 5rem;
    background: var(--blur-blue);
  }

  .hero-glow-orange {
    right: -5rem;
    bottom: -6rem;
    background: var(--blur-orange);
  }
</style>
