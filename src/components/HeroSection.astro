---
import { ChevronLeft, ChevronRight } from "lucide-react";
import { siteContent, whatsappHref } from "../lib/cms";

const hero = siteContent.home.hero;
---

{
  hero.enabled && (
    <section
      id="inicio"
      class="relative flex min-h-[86vh] w-full items-center overflow-hidden"
      data-hero-root
      data-reveal
    >
      <div class="hero-carousel absolute inset-0" data-hero-carousel>
        <div class="hero-track" data-hero-track>
          {hero.slides.map((slide, index) => (
            <div class="hero-slide">
              <img
                src={slide.image}
                alt={slide.alt}
                class="h-full w-full object-cover"
                loading={index === 0 ? "eager" : "lazy"}
                fetchpriority={index === 0 ? "high" : undefined}
                draggable="false"
              />
            </div>
          ))}
        </div>

        <button
          class="hero-arrow hero-arrow-left"
          type="button"
          data-hero-prev
          aria-label="Imagem anterior"
        >
          <ChevronLeft className="h-5 w-5" />
        </button>

        <button
          class="hero-arrow hero-arrow-right"
          type="button"
          data-hero-next
          aria-label="Próxima imagem"
        >
          <ChevronRight className="h-5 w-5" />
        </button>

        <div
          class="hero-pagination"
          data-hero-pagination
          aria-label="Paginação do carrossel"
        >
          {hero.slides.map((_, index) => (
            <button
              type="button"
              class:list={["hero-bullet", index === 0 && "is-active"]}
              aria-label={`Ir para imagem ${index + 1}`}
            />
          ))}
        </div>
      </div>

      <div class="relative pointer-events-none mx-auto flex w-full max-w-295 flex-col items-start px-4 pt-24 sm:px-6 lg:px-10">
        <h1
          class="max-w-4xl text-hero-title font-bold leading-[1.12] text-white"
          data-reveal
          data-reveal-delay="1"
        >
          {hero.title}
        </h1>

        <p
          class="mt-3 max-w-2xl text-base font-medium text-white/88 sm:text-[1.2rem]"
          data-reveal
          data-reveal-delay="2"
        >
          {hero.subtitle}
        </p>

        <a
          href={whatsappHref(hero.ctaMessage)}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Agende uma visita Técnica"
          data-cta-open-modal
          data-redirect-url={whatsappHref(hero.ctaMessage)}
          class="flex flex-row gap-2 pointer-events-auto mt-7 rounded-pill bg-emerald-500 px-7 py-3 text-base font-semibold text-white shadow-[0_10px_24px_rgba(16,185,129,0.36)] transition-all duration-200 hover:-translate-y-0.5 hover:brightness-110"
          data-reveal
          data-reveal-delay="3"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <g clip-path="url(#clip0_5_10)">
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M9.9971 0C4.48428 0 0 4.48553 0 9.99991C0 12.1868 0.705268 14.215 1.90417 15.8612L0.658162 19.5766L4.50185 18.3481C6.08275 19.3946 7.96934 20 10.0029 20C15.5157 20 20 15.5143 20 10.0001C20 4.48571 15.5157 0.000165304 10.0029 0.000165304L9.9971 0ZM7.20535 5.07951C7.01145 4.61511 6.86449 4.59753 6.57074 4.58558C6.47072 4.57978 6.35925 4.57397 6.23568 4.57397C5.85352 4.57397 5.45394 4.68564 5.21294 4.93252C4.91918 5.23233 4.19034 5.93182 4.19034 7.36633C4.19034 8.80084 5.23649 10.1882 5.37748 10.3823C5.52444 10.5761 7.41699 13.5626 10.3555 14.7798C12.6535 15.7321 13.3354 15.6439 13.8584 15.5322C14.6224 15.3676 15.5804 14.803 15.8214 14.1213C16.0624 13.4392 16.0624 12.8572 15.9918 12.7337C15.9213 12.6103 15.7272 12.5399 15.4335 12.3928C15.1397 12.2458 13.7114 11.5403 13.441 11.4462C13.1765 11.3463 12.9239 11.3817 12.7242 11.6639C12.442 12.0578 12.1658 12.4576 11.9424 12.6985C11.7661 12.8867 11.478 12.9102 11.2371 12.8102C10.9139 12.6751 10.0089 12.3574 8.89208 11.3639C8.02807 10.5939 7.4404 9.63573 7.27005 9.3477C7.09954 9.05386 7.25245 8.88313 7.38747 8.72452C7.53443 8.54218 7.67543 8.41293 7.82239 8.24236C7.96935 8.07197 8.05163 7.9837 8.14568 7.78378C8.24569 7.58982 8.17502 7.38989 8.10453 7.24289C8.03403 7.09589 7.44636 5.66138 7.20535 5.07951Z"
                fill="#fafafa"
              />
            </g>
            <defs>
              <clipPath id="clip0_5_10">
                <rect width="20" height="20" fill="white" />
              </clipPath>
            </defs>
          </svg>

          {hero.ctaText}
        </a>

        <div class="mt-4 flex flex-wrap items-center justify-center gap-3 text-sm sm:text-[0.95rem]">
          {hero.stats.map((stat, index) => (
            <span
              class:list={[
                index === 0 ? "font-medium text-secondary" : "text-star",
              ]}
            >
              {stat}
            </span>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .hero-carousel {
    z-index: 0;
    touch-action: pan-y;
    user-select: none;
  }

  .hero-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 320ms ease;
    will-change: transform;
  }

  .hero-slide {
    flex: 0 0 100%;
    height: 100%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      rgba(6, 18, 31, 0.8) 6%,
      rgba(6, 18, 31, 0.5) 42%,
      rgba(6, 18, 31, 0.62) 100%
    );
    pointer-events: none;
  }

  .hero-arrow {
    position: absolute;
    top: 50%;
    z-index: 8;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 999px;
    color: white;
    background: rgba(12, 18, 28, 0.32);
    transform: translateY(-50%);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .hero-arrow:hover {
    background: rgba(12, 18, 28, 0.58);
    border-color: rgba(255, 255, 255, 0.8);
  }

  .hero-arrow:active {
    transform: translateY(-50%) scale(0.97);
  }

  .hero-arrow-left {
    left: 1rem;
  }

  .hero-arrow-right {
    right: 1rem;
  }

  .hero-pagination {
    position: absolute;
    left: 50%;
    bottom: 1.1rem;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transform: translateX(-50%);
  }

  .hero-bullet {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    border: 0;
    appearance: none;
    flex: 0 0 auto;
    opacity: 1;
    background-color: rgba(255, 255, 255, 0.65);
    transition:
      width 230ms ease,
      background-color 230ms ease;
  }

  .hero-bullet.is-active {
    width: 1.7rem;
    background-color: var(--color-secondary);
  }

  .hero-glow {
    position: absolute;
    width: 26rem;
    height: 26rem;
    border-radius: 999px;
    filter: blur(var(--blur-hero-glow));
    z-index: 1;
  }

  .hero-glow-blue {
    left: -5rem;
    top: 5rem;
    background: var(--blur-blue);
  }

  .hero-glow-orange {
    right: -5rem;
    bottom: -6rem;
    background: var(--blur-orange);
  }

  .hero-glow-green {
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: var(--blur-green);
  }

  @media (max-width: 768px) {
    .hero-arrow {
      width: 2.2rem;
      height: 2.2rem;
    }

    .hero-arrow-left {
      left: 0.6rem;
    }

    .hero-arrow-right {
      right: 0.6rem;
    }
  }
</style>

<script>
  const heroRoots = document.querySelectorAll("[data-hero-root]");

  heroRoots.forEach((root) => {
    const carousel = root.querySelector<HTMLElement>("[data-hero-carousel]");
    const track = root.querySelector<HTMLElement>("[data-hero-track]");
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-hero-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-hero-next]");
    const bullets = Array.from(
      root.querySelectorAll<HTMLButtonElement>(
        "[data-hero-pagination] .hero-bullet",
      ),
    );
    const slides = Array.from(track?.children ?? []);

    if (
      !carousel ||
      !track ||
      slides.length < 1 ||
      bullets.length !== slides.length
    )
      return;

    let activeIndex = 0;
    let touchStartX = 0;
    let touchCurrentX = 0;
    let isSwiping = false;

    const goTo = (nextIndex: number) => {
      activeIndex = (nextIndex + slides.length) % slides.length;
      track.style.transform = `translateX(-${activeIndex * 100}%)`;

      bullets.forEach((bullet, index) => {
        const isActive = index === activeIndex;
        bullet.classList.toggle("is-active", isActive);
        bullet.setAttribute("aria-current", isActive ? "true" : "false");
      });
    };

    prevBtn?.addEventListener("click", () => goTo(activeIndex - 1));
    nextBtn?.addEventListener("click", () => goTo(activeIndex + 1));

    bullets.forEach((bullet, index) => {
      bullet.addEventListener("click", () => goTo(index));
    });

    root.addEventListener(
      "touchstart",
      (event: TouchEvent) => {
        const target = event.target as HTMLElement | null;
        if (target?.closest("a, button")) return;
        touchStartX = event.touches[0]?.clientX ?? 0;
        touchCurrentX = touchStartX;
        isSwiping = true;
      },
      { passive: true },
    );

    root.addEventListener(
      "touchmove",
      (event: TouchEvent) => {
        if (!isSwiping) return;
        touchCurrentX = event.touches[0]?.clientX ?? touchCurrentX;
      },
      { passive: true },
    );

    root.addEventListener("touchend", () => {
      if (!isSwiping) return;

      const deltaX = touchCurrentX - touchStartX;
      const threshold = 45;

      if (Math.abs(deltaX) > threshold) {
        goTo(deltaX < 0 ? activeIndex + 1 : activeIndex - 1);
      }

      isSwiping = false;
    });

    carousel.addEventListener("touchcancel", () => {
      isSwiping = false;
    });

    goTo(0);
  });
</script>
