---
import { Star } from "lucide-react";
import { siteContent, whatsappHref } from "../lib/cms";

const section = siteContent.home.testimonials;
const testimonials = section.items;

const slides = [...testimonials, ...testimonials];
---

{
  section.enabled && (
    <section
      class="mx-auto flex w-full max-w-[1180px] flex-col px-4 py-8 sm:px-6 lg:px-10"
      data-reveal
    >
      <div class="flex flex-wrap items-center gap-3">
        <h2
          class="font-display text-h2 font-bold text-text-strong"
          data-reveal
          data-reveal-delay="1"
        >
          {section.title}
        </h2>
        <span class="text-sm font-medium text-secondary">
          {section.highlight}
        </span>
        <span class="flex items-center gap-1 text-sm text-star">
          <Star className="h-4 w-4 fill-current" /> {section.ratingText}
        </span>
      </div>

      <div class="carousel-mask mt-5">
        <div class="carousel-track flex items-stretch gap-4">
          {slides.map((item, idx) => (
            <article
              class="flex min-h-[126px] min-w-[320px] max-w-[360px] flex-1 items-start gap-3 rounded-[24px] border border-border-soft bg-bg-surface px-4 py-4 shadow-soft"
              aria-hidden={idx >= testimonials.length ? "true" : "false"}
            >
              <img
                src={item.avatar}
                alt={`Avatar de ${item.name}`}
                class="h-12 w-12 shrink-0 rounded-full object-cover"
                loading="lazy"
              />
              <div class="flex min-w-0 flex-col">
                <div class="flex items-center gap-2">
                  <strong class="truncate text-sm font-semibold text-text-strong">
                    {item.name}
                  </strong>
                  <span class="flex items-center gap-0.5 text-xs text-star">
                    <Star className="h-3 w-3 fill-current" />
                    <Star className="h-3 w-3 fill-current" />
                    <Star className="h-3 w-3 fill-current" />
                    <Star className="h-3 w-3 fill-current" />
                    <Star className="h-3 w-3 fill-current" />
                  </span>
                </div>
                <p class="mt-1 text-sm leading-[1.4] text-text-body">
                  {item.text}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="mt-9 flex flex-col items-center text-center">
        <p class="text-sm text-text-soft" data-reveal data-reveal-delay="2">
          {section.preCtaText}
        </p>
        <a
          href={whatsappHref(section.ctaMessage)}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Agende uma visita Técnica"
          data-cta-open-modal
          data-redirect-url={whatsappHref(section.ctaMessage)}
          class="flex flex-row gap-2 pointer-events-auto mt-7 rounded-pill bg-emerald-500 px-7 py-3 text-base font-semibold text-white shadow-[0_10px_24px_rgba(16,185,129,0.36)] transition-all duration-200 hover:-translate-y-0.5 hover:brightness-110"
          data-reveal
          data-reveal-delay="3"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <g clip-path="url(#clip0_5_10)">
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M9.9971 0C4.48428 0 0 4.48553 0 9.99991C0 12.1868 0.705268 14.215 1.90417 15.8612L0.658162 19.5766L4.50185 18.3481C6.08275 19.3946 7.96934 20 10.0029 20C15.5157 20 20 15.5143 20 10.0001C20 4.48571 15.5157 0.000165304 10.0029 0.000165304L9.9971 0ZM7.20535 5.07951C7.01145 4.61511 6.86449 4.59753 6.57074 4.58558C6.47072 4.57978 6.35925 4.57397 6.23568 4.57397C5.85352 4.57397 5.45394 4.68564 5.21294 4.93252C4.91918 5.23233 4.19034 5.93182 4.19034 7.36633C4.19034 8.80084 5.23649 10.1882 5.37748 10.3823C5.52444 10.5761 7.41699 13.5626 10.3555 14.7798C12.6535 15.7321 13.3354 15.6439 13.8584 15.5322C14.6224 15.3676 15.5804 14.803 15.8214 14.1213C16.0624 13.4392 16.0624 12.8572 15.9918 12.7337C15.9213 12.6103 15.7272 12.5399 15.4335 12.3928C15.1397 12.2458 13.7114 11.5403 13.441 11.4462C13.1765 11.3463 12.9239 11.3817 12.7242 11.6639C12.442 12.0578 12.1658 12.4576 11.9424 12.6985C11.7661 12.8867 11.478 12.9102 11.2371 12.8102C10.9139 12.6751 10.0089 12.3574 8.89208 11.3639C8.02807 10.5939 7.4404 9.63573 7.27005 9.3477C7.09954 9.05386 7.25245 8.88313 7.38747 8.72452C7.53443 8.54218 7.67543 8.41293 7.82239 8.24236C7.96935 8.07197 8.05163 7.9837 8.14568 7.78378C8.24569 7.58982 8.17502 7.38989 8.10453 7.24289C8.03403 7.09589 7.44636 5.66138 7.20535 5.07951Z"
                fill="#fafafa"
              />
            </g>
            <defs>
              <clipPath id="clip0_5_10">
                <rect width="20" height="20" fill="white" />
              </clipPath>
            </defs>
          </svg>

          {section.ctaText}
        </a>
        <p class="mt-4 text-sm text-text-body">{section.bottomText}</p>
      </div>
    </section>
  )
}

<style>
  .carousel-mask {
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .carousel-track {
    width: max-content;
    animation: testimonials-autoplay 30s linear infinite;
  }

  .carousel-mask:hover .carousel-track {
    animation-play-state: paused;
  }

  @keyframes testimonials-autoplay {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-50% - 8px));
    }
  }

  @media (max-width: 640px) {
    .carousel-track {
      animation-duration: 22s;
    }
  }
</style>
