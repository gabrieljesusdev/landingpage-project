---
import { Star } from "lucide-react";
import { siteContent, whatsappHref } from "../lib/cms";

const section = siteContent.home.testimonials;
const testimonials = section.items;

const slides = [...testimonials, ...testimonials];
---

{
  section.enabled && (
    <section
      class="mx-auto flex w-full max-w-[1180px] flex-col px-4 py-8 sm:px-6 lg:px-10"
      data-reveal
    >
  <div class="flex flex-wrap items-center gap-3">
    <h2
      class="font-display text-h2 font-bold text-text-strong"
      data-reveal
      data-reveal-delay="1"
    >
      {section.title}
    </h2>
    <span class="text-sm font-medium text-secondary"
      >{section.highlight}</span
    >
    <span class="flex items-center gap-1 text-sm text-star">
      <Star className="h-4 w-4 fill-current" /> {section.ratingText}
    </span>
  </div>

  <div class="carousel-mask mt-5">
    <div class="carousel-track flex items-stretch gap-4">
      {
        slides.map((item, idx) => (
          <article
            class="flex min-h-[126px] min-w-[320px] max-w-[360px] flex-1 items-start gap-3 rounded-[24px] border border-border-soft bg-bg-surface px-4 py-4 shadow-soft"
            aria-hidden={idx >= testimonials.length ? "true" : "false"}
          >
            <img
              src={item.avatar}
              alt={`Avatar de ${item.name}`}
              class="h-12 w-12 shrink-0 rounded-full object-cover"
              loading="lazy"
            />
            <div class="flex min-w-0 flex-col">
              <div class="flex items-center gap-2">
                <strong class="truncate text-sm font-semibold text-text-strong">
                  {item.name}
                </strong>
                <span class="flex items-center gap-0.5 text-xs text-star">
                  <Star className="h-3 w-3 fill-current" />
                  <Star className="h-3 w-3 fill-current" />
                  <Star className="h-3 w-3 fill-current" />
                  <Star className="h-3 w-3 fill-current" />
                  <Star className="h-3 w-3 fill-current" />
                </span>
              </div>
              <p class="mt-1 text-sm leading-[1.4] text-text-body">
                {item.text}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <div class="mt-9 flex flex-col items-center text-center">
    <p class="text-sm text-text-soft" data-reveal data-reveal-delay="2">
      {section.preCtaText}
    </p>
    <a
      href={whatsappHref(section.ctaMessage)}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 rounded-pill bg-secondary px-8 py-3 text-base font-semibold text-white shadow-button transition-all duration-200 hover:-translate-y-0.5 hover:brightness-110"
      data-reveal
      data-reveal-delay="3"
    >
      {section.ctaText}
    </a>
    <p class="mt-4 text-sm text-text-body">
      {section.bottomText}
    </p>
  </div>
</section>
  )
}

<style>
  .carousel-mask {
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .carousel-track {
    width: max-content;
    animation: testimonials-autoplay 30s linear infinite;
  }

  .carousel-mask:hover .carousel-track {
    animation-play-state: paused;
  }

  @keyframes testimonials-autoplay {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-50% - 8px));
    }
  }

  @media (max-width: 640px) {
    .carousel-track {
      animation-duration: 22s;
    }
  }
</style>
