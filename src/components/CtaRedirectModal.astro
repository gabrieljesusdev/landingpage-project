---
import { siteContent, whatsappHref } from "../lib/cms";

const fallbackRedirectUrl = whatsappHref(siteContent.navbar.ctaMessage);
---

<div
  data-navbar-cta-modal
  data-fallback-redirect-url={fallbackRedirectUrl}
  class="pointer-events-none fixed inset-0 z-60 hidden items-center justify-center bg-black/55 px-4 opacity-0 transition-opacity duration-220 ease-out"
>
  <div
    data-navbar-cta-card
    class="w-full max-w-md rounded-2xl bg-white p-6 shadow-xl opacity-0 translate-y-3 scale-[0.97] transition-all duration-220 ease-out"
  >
    <h3 class="font-display text-2xl font-semibold text-text-strong">
      Estou redirecionando você
    </h3>

    <p class="mt-3 text-sm leading-relaxed text-text-body">
      O valor minimo da visita é R$100,00 paga quando o técnico analisa o
      problema no estabelecimento.
    </p>

    <p class="mt-4 text-5xl font-extrabold leading-none text-emerald-500">
      R$100,00
    </p>

    <p class="mt-4 text-sm font-medium text-text-soft">
      Redirecionando em
      <span data-navbar-cta-countdown class="font-bold text-text-strong">3</span
      >
      segundos.
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <button
        type="button"
        data-navbar-cta-cancel
        class="rounded-pill border border-border-soft px-5 py-2 text-sm font-semibold text-text-body transition-colors duration-200 hover:bg-gray-100"
      >
        Cancelar
      </button>
      <button
        type="button"
        data-navbar-cta-redirect
        class="rounded-pill bg-emerald-500 px-5 py-2 text-sm font-semibold text-white transition-all duration-200 hover:brightness-110"
      >
        Redirecionar
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const modal = document.querySelector("[data-navbar-cta-modal]");
    const modalCard = document.querySelector("[data-navbar-cta-card]");
    const countdown = document.querySelector("[data-navbar-cta-countdown]");
    const cancelButton = document.querySelector("[data-navbar-cta-cancel]");
    const redirectButton = document.querySelector("[data-navbar-cta-redirect]");

    if (
      !modal ||
      !modalCard ||
      !countdown ||
      !cancelButton ||
      !redirectButton
    ) {
      return;
    }

    const animationDurationMs = 220;
    const initialSeconds = 100;
    const fallbackUrl = modal.getAttribute("data-fallback-redirect-url") || "";

    let secondsLeft = initialSeconds;
    let timerId = null;
    let closeTimeoutId = null;
    let redirectUrl = fallbackUrl;

    const clearTimers = () => {
      if (timerId) {
        window.clearInterval(timerId);
        timerId = null;
      }

      if (closeTimeoutId) {
        window.clearTimeout(closeTimeoutId);
        closeTimeoutId = null;
      }
    };

    const hideModal = () => {
      clearTimers();

      modal.classList.add("opacity-0", "pointer-events-none");
      modalCard.classList.add("opacity-0", "translate-y-3", "scale-[0.97]");
      modalCard.classList.remove("opacity-100", "translate-y-0", "scale-100");

      closeTimeoutId = window.setTimeout(() => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
      }, animationDurationMs);
    };

    const redirectNow = () => {
      hideModal();
      if (redirectUrl) {
        window.open(redirectUrl, "_blank", "noopener,noreferrer");
      }
    };

    const openModal = (nextUrl) => {
      clearTimers();

      redirectUrl = nextUrl || fallbackUrl;
      secondsLeft = initialSeconds;
      countdown.textContent = String(secondsLeft);
      modal.classList.remove("hidden");
      modal.classList.add("flex");

      window.requestAnimationFrame(() => {
        modal.classList.remove("opacity-0", "pointer-events-none");
        modalCard.classList.remove(
          "opacity-0",
          "translate-y-3",
          "scale-[0.97]",
        );
        modalCard.classList.add("opacity-100", "translate-y-0", "scale-100");
      });

      timerId = window.setInterval(() => {
        secondsLeft -= 1;
        countdown.textContent = String(Math.max(secondsLeft, 0));

        if (secondsLeft <= 0) {
          redirectNow();
        }
      }, 1000);
    };

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const trigger = target.closest(
        "[data-navbar-cta-open], [data-cta-open-modal]",
      );
      if (!trigger) return;

      event.preventDefault();
      const nextUrl = trigger.getAttribute("data-redirect-url") || "";
      openModal(nextUrl);
    });

    window.addEventListener("open-site-cta-modal", (event) => {
      const customEvent = event;
      const nextUrl = customEvent?.detail?.redirectUrl || "";
      openModal(nextUrl);
    });

    cancelButton.addEventListener("click", hideModal);
    redirectButton.addEventListener("click", redirectNow);

    modal.addEventListener("click", (event) => {
      if (event.target === modal) {
        hideModal();
      }
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        hideModal();
      }
    });
  })();
</script>

<style>
  @media (prefers-reduced-motion: reduce) {
    [data-navbar-cta-modal],
    [data-navbar-cta-card] {
      transition: none;
    }
  }
</style>
